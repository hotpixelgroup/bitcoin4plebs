{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/app",
    "tsBuildInfoFile": "out-tsc/app/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom", "es2022"],
    "types": ["node", "vite/client"],
    "rootDir": "src"
  },
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/test-setup.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    { "path": "../../packages/bitcoin-logic/tsconfig.lib.json" },
    { "path": "../../packages/quests/tsconfig.lib.json" },
    { "path": "../../packages/ui/tsconfig.lib.json" }
  ]
}
